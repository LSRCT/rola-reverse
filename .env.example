# Copy to .env and fill in. .env is gitignored; never commit real values.

# Enabot account credentials.
ENABOT_ACCOUNT=
ENABOT_PASSWORD=

# Optional SDK client identity used in the Enabot login payload.
# Leave blank to generate and persist one in .enabot/device_id.
ENABOT_DEVICE_ID=

# Reusable app constants extracted from the ROLA app.
ENABOT_APP_TOKEN=
ENABOT_ACCESS_KEY_SECRET_S2=
ENABOT_BODY_ENCRYPT_KEY_S2=
AGORA_APP_ID=

# Optional defaults.
ENABOT_LOGIN_REGION=GB
ENABOT_PHONE_AREA=
ENABOT_LANGUAGE=en
ENABOT_ACCEPT_LANGUAGE=en
