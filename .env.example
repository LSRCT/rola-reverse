# Copy to .env and fill in. .env is gitignored; never commit real values.

# Enabot account credentials.
ENABOT_ACCOUNT=
ENABOT_PASSWORD=

# Stable client/device identity used in the Enabot login payload.
ENABOT_DEVICE_ID=

# Target robot.
ENABOT_ROBOT_ID=

# App constants extracted from the ROLA app.
ENABOT_APP_TOKEN=
ENABOT_ACCESS_KEY_SECRET_S2=
ENABOT_BODY_ENCRYPT_KEY_S2=
AGORA_APP_ID=

# Optional defaults.
ENABOT_LOGIN_REGION=GB
ENABOT_PHONE_AREA=
ENABOT_LANGUAGE=en
ENABOT_ACCEPT_LANGUAGE=en
